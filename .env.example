# ========================================
# NEXTAUTH CONFIGURATION
# ========================================
# Generate a secure random secret:
# Command: openssl rand -base64 32
# Or visit: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=your-secure-random-secret-here

# Your application URL
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000

# ========================================
# APPWRITE CONFIGURATION
# ========================================
# Get these from: https://cloud.appwrite.io/console
# Project → Settings

# Appwrite endpoint (Cloud or self-hosted)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Secret used by Vercel Cron to authorize keep-alive endpoint calls
# Generate with: openssl rand -hex 32
CRON_SECRET=cee487521cd339bb37bab9635387b6a3

# Optional: enforce CRON_SECRET auth for keepalive endpoint in all environments.
# Default behavior allows keepalive without auth when CRON_SECRET is not set.
REQUIRE_CRON_SECRET=false

# Your Appwrite Project ID
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-project-id-here

# Project name (optional)
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=your-project-name

# ========================================
# DATABASE & COLLECTIONS
# ========================================
# Create in: Databases → Collections
# Copy IDs from collection settings

NEXT_PUBLIC_APPWRITE_DATABASE_ID=your-database-id
NEXT_PUBLIC_APPWRITE_PERFUMES_COLLECTION_ID=your-perfumes-collection-id
NEXT_PUBLIC_APPWRITE_USERS_COLLECTION_ID=your-users-collection-id
NEXT_PUBLIC_APPWRITE_ORDERS_COLLECTION_ID=your-orders-collection-id

# ========================================
# SERVER-SIDE API KEY (REQUIRED FOR IMAGE LOADING)
# ========================================
# Create in: Appwrite Console → Overview → API Keys
# Click "Create API Key"
# Name: "Server API Key"
# Scopes: Enable "files.read" (or all scopes for full access)
# IMPORTANT: This key is ONLY used server-side, never exposed to client
# Without this key, images will return 403 Forbidden errors
APPWRITE_API_KEY=your-api-key-here

# ========================================
# STORAGE BUCKETS
# ========================================
# Create in: Storage → Buckets
# Copy Bucket IDs from settings

NEXT_PUBLIC_APPWRITE_PERFUME_IMAGES_BUCKET_ID=your-bucket-id-here
NEXT_PUBLIC_APPWRITE_NOTE_IMAGES_BUCKET_ID=your-note-images-bucket-id

# ========================================
# SERVER-SIDE API KEY (OPTIONAL)
# ========================================
# Only needed if you want to keep buckets PRIVATE
# For public product images, you can skip this and set bucket permissions to "Any" with Read access
# 
# To generate:
# 1. Appwrite Console → Overview → Integrations → API Keys
# 2. Create API Key with scopes: files.read, storage.read
# 3. Copy the key and paste below
# 
# WARNING: Keep this secret! Never expose in client-side code or commit to Git
APPWRITE_API_KEY=

# ========================================
# IMAGE SERVING STRATEGY
# ========================================
# Options: 'proxy' (recommended) or 'direct'
# 
# NOTE: Appwrite FREE TIER does not support image transformations (resize, crop, etc.)
# Images are served in their original uploaded size and format.
# Use CSS for client-side resizing (e.g., object-fit, max-width, etc.)
NEXT_PUBLIC_IMAGE_STRATEGY=proxy

# ========================================
# EMAIL — RESEND
# ========================================
# Get your API key from: https://resend.com/api-keys
# Domain must be verified in Resend dashboard before sending
#
# From address: contact@talelio.shop  (domain must be verified)
# Admin notifications are sent to: talelio@outlook.com
RESEND_API_KEY=your-resend-api-key-here

# ========================================
# SETUP INSTRUCTIONS
# ========================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in all values from Appwrite Console
# 3. Generate secure NEXTAUTH_SECRET
# 4. Configure bucket permissions (see below)
# 5. NEVER commit .env.local to Git!
# 
# BUCKET PERMISSIONS SETUP:
# Option A (Easier - for public product images):
#   - Go to Storage → Your Bucket → Settings → Permissions
#   - Add: Role "Any" with "Read" permission
#   - No API key needed
# 
# Option B (More secure - private buckets):
#   - Keep bucket private
#   - Generate API key (see above)
#   - Set APPWRITE_API_KEY
# 
# See APPWRITE_SETUP.md for detailed setup guide